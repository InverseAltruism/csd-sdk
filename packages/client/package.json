{
  "name": "@inversealtruism/csd-client",
  "version": "0.1.15",
  "engines": { "node": ">=18" },
  "description": "Typed HTTP RPC client for a Compute Substrate node (or the Cairn proxy / a discovered gateway) \u2014 tip/block/tx/utxos/proposals/top/domains/mempool/submit/templates.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "tsx test/client.test.ts && tsx test/hostile.test.ts",
    "prepublishOnly": "node ../../scripts/publish-guard.mjs"
  },
  "dependencies": {
    "@inversealtruism/csd-codec": "workspace:*"
  },
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@inversealtruism/csd-vectors": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InverseAltruism/csd-sdk.git",
    "directory": "packages/client"
  },
  "homepage": "https://cairn-substrate.com"
}
