{
  "name": "@inversealtruism/csd-registry",
  "version": "0.1.3",
  "description": "Compute Substrate L3 registries — peer/gateway/identity discovery built entirely on the Propose/Attest primitive. Pure deterministic resolvers (replay an epoch set → identical result anywhere) + commit-reveal identity + client-side or indexer-served discovery. No new tx types, no fork.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "tsx test/registry.test.ts"
  },
  "dependencies": {
    "@inversealtruism/csd-codec": "workspace:*",
    "@inversealtruism/csd-crypto": "workspace:*"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InverseAltruism/csd-sdk.git",
    "directory": "packages/registry"
  },
  "homepage": "https://cairn-substrate.com"
}
