{
  "name": "@inversealtruism/csd-vectors",
  "version": "0.1.15",
  "engines": { "node": ">=18" },
  "description": "Golden conformance vectors for Compute Substrate \u2014 the contract every @inversealtruism/csd-* impl must match. Sourced from the Rust node's frozen tests/golden_vectors.rs + real on-chain data.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "tsx test/vectors.test.ts",
    "prepublishOnly": "node ../../scripts/publish-guard.mjs"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InverseAltruism/csd-sdk.git",
    "directory": "packages/vectors"
  },
  "homepage": "https://cairn-substrate.com"
}
