{
  "name": "csd-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Compute Substrate (CSD) SDK + light client — L0 of the no-fork ecosystem roadmap. One canonical, golden-vector-tested toolkit for building on CSD.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* build",
    "test": "pnpm -r --filter ./packages/* test",
    "clean": "pnpm -r exec node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
